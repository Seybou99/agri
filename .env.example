# Configuration de l'application
# Phase 1 : mettre l'URL de l'API Vercel (ex. https://ton-projet.vercel.app) pour utiliser /api/v1/*
API_URL=https://api.example.com
API_KEY=your_api_key_here

# Environnement
ENV=development

# Firebase — projet SeneGundo : agriculture-b70c9 (Auth + Firestore + règles firestore.rules)
# Ne pas mettre FIREBASE_* dans .env.local (vercel pull) : autre projet → erreurs "permission denied".
# Déployer les règles : firebase deploy --only firestore:rules --project agriculture-b70c9

# Firebase — app mobile (Console → Paramètres du projet → Vos applications → Web)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef
# Connexion Google — 2 clients dans Google Cloud (même projet agriculture-b70c9)
# Web : pour Firebase (URI https:// uniquement sur ce client)
GOOGLE_WEB_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com
# iOS : Créer identifiants → ID client OAuth → Application iOS → Bundle ID com.senegundo.app
GOOGLE_IOS_CLIENT_ID=123456789-xxxx-ios.apps.googleusercontent.com
# Android (optionnel) : Application Android → com.senegundo.app + empreinte SHA-1
# GOOGLE_ANDROID_CLIENT_ID=123456789-xxxx-android.apps.googleusercontent.com

# Supabase (Phase 1 - persistance diagnostics)
# Créer un projet sur https://supabase.com, puis exécuter docs/DB_SCHEMA_SUPABASE_MINIMAL.sql dans SQL Editor
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# APIs externes
# Pl@ntNet — maladies des plantes (backend Vercel uniquement, pas dans l'app)
# Inscription : https://my.plantnet.org — 500 identifications/jour en gratuit
PLANTNET_API_KEY=your_plantnet_private_api_key

# Kindwise Crop.health (fallback si quota Pl@ntNet) — https://crop.kindwise.com
# 100 crédits/jour gratuits · header Api-Key · POST https://crop.kindwise.com/api/v1/identification
PLANT_ID_API_KEY=your_kindwise_crop_health_api_key

OPENWEATHER_API_KEY=your_openweather_api_key
# AgroMonitoring (surveillance agricole, NDVI, météo parcelle) — https://home.agromonitoring.com → Clés d'API
AGROMONITORING_API_KEY=your_agromonitoring_api_key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Google Earth Engine (backend uniquement — jamais dans l'app mobile ni dans Git)
# Cloud Functions : chemin vers le fichier JSON du compte de service
GOOGLE_APPLICATION_CREDENTIALS=./path/to/your-service-account.json
GEE_PROJECT_ID=my-project-agricol
# Vercel : mettre le JSON en chaîne dans GEE_SERVICE_ACCOUNT_JSON (voir docs/EARTH_ENGINE_SETUP.md)
# GEE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# iSDAsoil (backend Vercel uniquement — compte gratuit https://api.isda-africa.com)
# ISDA_USERNAME=votre_email@example.com
# ISDA_PASSWORD=votre_mot_de_passe
